{
  "ConnectionStrings": {
    "Database": "Host=eternelle.database;Port=5432;Database=eternelle;Username=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "eternelle.redis:6379"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [ "http://eternelle.identity:8080/realms/eternelle", "http://localhost:18080/realms/eternelle" ]
    },
    "MetadataAddress": "http://eternelle.identity:8080/realms/eternelle/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://eternelle.identity:9000/health/"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Eternelle.Modules.Weddings.Infrastructure.Outbox": "Warning",
        "Eternelle.Modules.Weddings.Infrastructure.Inbox": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://eternelle.seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "Eternelle.Api"
    }
  },
  "Weddings": {
    "SnapShare": {
      "UploadBaseUrl": "https://app.eternelle.ph/photos/upload"
    },
    "Subscription": {
      "PhotoUploadLimit": null
    },
    "PhotoStorage": {
      "ServiceUrl": "http://eternelle.minio:9000",
      "PublicUrl": "http://localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "eternelle-photos"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://eternelle.jaeger:4317"
}
